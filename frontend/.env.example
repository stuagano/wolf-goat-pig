# Wolf Goat Pig Frontend Environment Variables
# Copy this file to .env.local for local development

# ============================================================================
# BACKEND API CONFIGURATION
# ============================================================================
# CRITICAL: This must be set in Vercel dashboard for production deployments
# Local development: Leave empty (uses proxy from vite.config.js)
# Production: Set to https://wolf-goat-pig.onrender.com in Vercel dashboard
VITE_API_URL=

# ============================================================================
# AUTH0 CONFIGURATION
# ============================================================================
VITE_AUTH0_DOMAIN=dev-jm88n088hpt7oe48.us.auth0.com
VITE_AUTH0_CLIENT_ID=qAZuRv5E9mPQ9uTGg7NWpkpfVj8bCeoB
VITE_AUTH0_AUDIENCE=https://wolf-goat-pig.onrender.com

# ============================================================================
# FEATURE FLAGS (Optional)
# ============================================================================
# Enable analytics tracking
VITE_ENABLE_ANALYTICS=false

# ============================================================================
# DEPLOYMENT METADATA (Optional)
# ============================================================================
# Deployment platform (auto-detected but can be overridden)
VITE_DEPLOY_PLATFORM=local

# ============================================================================
# VERCEL DEPLOYMENT INSTRUCTIONS
# ============================================================================
# To deploy to Vercel, set these environment variables in Vercel dashboard:
#
# 1. Go to your project settings in Vercel
# 2. Navigate to "Environment Variables"
# 3. Add these variables:
#
#    VITE_API_URL = https://wolf-goat-pig.onrender.com
#    VITE_AUTH0_DOMAIN = dev-jm88n088hpt7oe48.us.auth0.com
#    VITE_AUTH0_CLIENT_ID = qAZuRv5E9mPQ9uTGg7NWpkpfVj8bCeoB
#    VITE_AUTH0_AUDIENCE = https://wolf-goat-pig.onrender.com
#    VITE_ENABLE_ANALYTICS = true
#    VITE_DEPLOY_PLATFORM = vercel
#
# 4. Redeploy your app for changes to take effect
#
# ============================================================================

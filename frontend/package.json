{
  "name": "wgp-frontend",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.0.0 <26.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@auth0/auth0-react": "^2.4.0",
    "ghin": "^0.7.0",
    "html2canvas": "^1.4.1",
    "prop-types": "^15.8.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.8.2",
    "uuid": "^13.0.0",
    "ajv-keywords": "3.5.2"
  },
  "scripts": {
    "start": "vite",
    "prebuild": "node scripts/update-sw-version.js",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ci": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:coverage:ci": "vitest run --coverage",
    "test:hooks": "vitest run --testPathPattern=hooks/__tests__",
    "test:services": "vitest run --testPathPattern=services/__tests__",
    "test:components": "vitest run --testPathPattern=components/__tests__",
    "test:game": "vitest run --testPathPattern=components/game/__tests__",
    "lint": "eslint src/**/*.{js,jsx}",
    "typecheck": "tsc --noEmit",
    "prevercel-build": "node scripts/update-sw-version.js",
    "vercel-build": "vite build",
    "test:e2e": "playwright test --config tests/e2e/playwright.config.js",
    "test:e2e:ui": "playwright test --config tests/e2e/playwright.config.js --ui",
    "test:e2e:debug": "playwright test --config tests/e2e/playwright.config.js --debug",
    "test:e2e:headed": "playwright test --config tests/e2e/playwright.config.js --headed",
    "test:e2e:report": "playwright show-report",
    "test:e2e:production": "playwright test --config tests/e2e/playwright.production.config.js",
    "lint:deploy": "node scripts/lint-frontend-deploy.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.2.4",
    "jsdom": "^26.1.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.2",
    "vitest": "^3.2.4"
  }
}

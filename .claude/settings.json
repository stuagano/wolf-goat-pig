{
  "permissions": {
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm run test:*)",
      "Bash(npm test:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push)",
      "Bash(git config:*)",
      "Bash(git tag:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git stash:*)",
      "Bash(jq:*)",
      "Bash(node:*)",
      "Bash(which:*)",
      "Bash(pwd)",
      "Bash(ls:*)"
    ],
    "deny": [
      "Bash(rm -rf /)"
    ]
  },
  "enabledPlugins": {
    "pr-review-toolkit@claude-plugins-official": true
  },
  "hooks": {
    "Stop": [
      {
        "_caps": "caps-stop-gate",
        "hooks": [
          {
            "type": "command",
            "command": "CAPS_GATE_PYTHON=\"$CLAUDE_PROJECT_DIR/backend/venv/bin/python\" \"$CLAUDE_PROJECT_DIR/.ctk/bin/caps-stop-gate.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
